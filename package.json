    "jose": "^6.1.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.554.0",
    "multer": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.5.0",
    "xlsx": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
