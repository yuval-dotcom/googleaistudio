# Copy to .env or .env.local and fill in values. Never commit .env.

# Supabase (required for real auth & data; optional for Demo Mode)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini API key – server-only, used by /api/ai (dev middleware + production server)
# Not exposed to the client.
GEMINI_API_KEY=your_gemini_api_key
