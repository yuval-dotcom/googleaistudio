{
  "version": 2,
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/server?__originalPath=/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server?__originalPath=/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
