{
  "compilerOptions": {
    "target": "ES2022",
    "outDir": "./dist-server",
    "rootDir": "./server",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "noEmit": false,
    "allowJs": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["server/**/*"]
}
